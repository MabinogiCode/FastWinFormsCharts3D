# Force consistent line endings
*           text=auto eol=lf
*.cs        text eol=lf
*.csproj    text eol=lf
*.sln       text eol=crlf
*.props     text eol=lf
*.targets   text eol=lf
*.json      text eol=lf
*.md        text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
*.vert      text eol=lf
*.frag      text eol=lf
*.editorconfig text eol=lf

# Binaries — no diff, no merge
*.png       binary
*.jpg       binary
*.ico       binary
*.dll       binary
*.nupkg     binary
*.snupkg    binary
